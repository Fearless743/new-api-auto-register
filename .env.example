# 本地主数据文件。账号、会话、签到历史和余额缓存都会统一存放在这里。
STORE_PATH=./data/store.json

# 上游站点根地址。代码会自动拼接固定的 API 路径。
BASE_URL=https://open.lxcloud.dev

# Web API 端口。部署后可通过 http://<服务器IP>:3000/api/balances 查询余额。
API_PORT=3000

# 管理员接口密钥。用于保护批量注册 API，请务必自行设置复杂值。
ADMIN_API_KEY=

# 每日签到计划，使用 cron 表达式和时区。
CHECKIN_CRON_EXPR=0 0 * * *
CHECKIN_CRON_TZ=Asia/Shanghai

# 每 10 分钟刷新一次真实余额，并把结果写入 store.json。
BALANCE_REFRESH_CRON_EXPR=*/10 * * * *
BALANCE_REFRESH_CRON_TZ=Asia/Shanghai

# 可选的自定义身份或 Cookie 头。除非目标站点确实要求，否则留空即可。
EXTRA_COOKIES=
NEW_API_USER=
